{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "node apps/api/dist/index.js",
    "healthcheckPath": "/api/auth/session",
    "restartPolicyType": "on-failure",
    "restartPolicyMaxRetries": 10
  }
}
